  "style": "{border.style.solid}"
}, "$type": "border" },
      "warning": { "$value": {
  "color": "{color.base.amber.500}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" },
      "info": { "$value": {
  "color": "{color.base.blue.500}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" }
    }
  }
}

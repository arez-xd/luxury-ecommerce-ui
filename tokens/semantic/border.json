{
  "border": {
    "control": {
      "default": { "$value": {
  "color": "{color.base.neutral.200}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" },
      "disabled": { "$value": {
  "color": "{color.base.neutral.100}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" },
      "focused": { "$value": {
  "color": "{color.base.gold.500}",
  "width": "{stroke.2}",
  "style": "{border.style.solid}"
}, "$type": "border" }
    },
    "separator": {
      "default": { "$value": {
  "color": "{color.base.neutral.100}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" },
      "strong": { "$value": {
  "color": "{color.base.neutral.200}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" }
    },
    "card": {
      "default": { "$value": {
  "color": "{color.base.neutral.100}",
  "width": "{stroke.1}",
  "style": "{border.style.solid}"
}, "$type": "border" }
    },
    "status": {
      "success": { "$value": {
